<!--
  ServerSettingsWindow.xaml
  =========================
  Modal dialog for editing TeamTalk server credentials. Grouped by
  concern (Server / User / Channel) so tab order flows naturally and
  screen-reader users can navigate by GroupBox heading.

  Every interactive control has AutomationProperties.Name for a clear
  screen-reader label. Password fields use PasswordBox (masked) with
  VM sync wired in code-behind because PasswordBox.Password isn't
  directly bindable.
-->
<Window x:Class="TeamTalkStreamer.App.Views.ServerSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        mc:Ignorable="d"
        Title="Server settings"
        Height="720" Width="480"
        MinHeight="560" MinWidth="440"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        automation:AutomationProperties.Name="TeamTalk server settings dialog"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Shared spacing/padding so the form looks consistent without
             repeating margin values on every control. -->
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="4,3" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="4,3" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="8" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="12" LastChildFill="True">

        <!-- ==================== Footer (docked bottom) ==================== -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="Save"
                    Width="90" Margin="0,0,8,0"
                    IsDefault="True"
                    Command="{Binding SaveCommand}"
                    automation:AutomationProperties.Name="Save settings"
                    automation:AutomationProperties.HelpText="Persist these credentials to the settings file and close the dialog" />
            <Button Content="Cancel"
                    Width="90"
                    IsCancel="True"
                    Command="{Binding CancelCommand}"
                    automation:AutomationProperties.Name="Cancel — discard changes" />
        </StackPanel>

        <!-- ==================== Scrollable form body ==================== -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- =============== Server section =============== -->
                <GroupBox Header="Server"
                          automation:AutomationProperties.HeadingLevel="Level2">
                    <StackPanel>
                        <TextBlock Text="Host (address or hostname):" />
                        <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                                 automation:AutomationProperties.Name="Server host address" />

                        <TextBlock Text="TCP port:" />
                        <TextBox Text="{Binding TcpPort, UpdateSourceTrigger=PropertyChanged}"
                                 automation:AutomationProperties.Name="Server TCP port" />

                        <TextBlock Text="UDP port:" />
                        <TextBox Text="{Binding UdpPort, UpdateSourceTrigger=PropertyChanged}"
                                 automation:AutomationProperties.Name="Server UDP port" />

                        <TextBlock Text="Server password (leave blank if none):" />
                        <PasswordBox x:Name="ServerPasswordBox"
                                     PasswordChanged="ServerPasswordBox_OnPasswordChanged"
                                     automation:AutomationProperties.Name="Server password"
                                     automation:AutomationProperties.HelpText="Optional — required only if the server itself has a password" />
                    </StackPanel>
                </GroupBox>

                <!-- =============== User identity section =============== -->
                <GroupBox Header="User"
                          automation:AutomationProperties.HeadingLevel="Level2">
                    <StackPanel>
                        <TextBlock Text="Nickname (shown to other users):" />
                        <TextBox Text="{Binding Nickname, UpdateSourceTrigger=PropertyChanged}"
                                 automation:AutomationProperties.Name="Display nickname" />

                        <TextBlock Text="Username (blank for anonymous):" />
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 automation:AutomationProperties.Name="Account username" />

                        <TextBlock Text="Password:" />
                        <PasswordBox x:Name="UserPasswordBox"
                                     PasswordChanged="UserPasswordBox_OnPasswordChanged"
                                     automation:AutomationProperties.Name="Account password" />
                    </StackPanel>
                </GroupBox>

                <!-- =============== Channel section ===============
                     Displays the currently-configured channel in the
                     same friendly format used in the browser below
                     (bare name plus parent context, no raw slashes).
                     The actual raw path is still stored internally
                     and handed to the SDK at join time — users just
                     don't have to look at it.
                -->
                <GroupBox Header="Channel"
                          automation:AutomationProperties.HeadingLevel="Level2">
                    <StackPanel>
                        <TextBlock Text="Selected channel:" FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedChannelFriendly, FallbackValue='(none configured)'}"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   Margin="0,0,0,10"
                                   automation:AutomationProperties.Name="Currently selected channel"
                                   automation:AutomationProperties.LiveSetting="Polite" />

                        <TextBlock Text="Channel password (leave blank if none):" />
                        <PasswordBox x:Name="ChannelPasswordBox"
                                     PasswordChanged="ChannelPasswordBox_OnPasswordChanged"
                                     automation:AutomationProperties.Name="Channel password" />
                    </StackPanel>
                </GroupBox>

                <!-- =============== Browse channels section ===============
                     Probes the server using the credentials already typed
                     in the form above, fetches every channel, and presents
                     them in a ListBox so the user can pick one without
                     guessing the path syntax. Selecting an entry writes
                     its path into the Channel path TextBox above.
                -->
                <GroupBox Header="Browse channels"
                          automation:AutomationProperties.HeadingLevel="Level2">
                    <StackPanel>
                        <TextBlock Text="Probe the server using the credentials above, then pick a channel from the list."
                                   TextWrapping="Wrap" />

                        <Button Content="Probe server for channel list"
                                Margin="0,6,0,6"
                                Height="30"
                                Command="{Binding BrowseChannelsCommand}"
                                IsEnabled="{Binding CanBrowse}"
                                automation:AutomationProperties.Name="Probe server and list available channels"
                                automation:AutomationProperties.HelpText="Temporarily logs into the server with the entered credentials, retrieves every channel, then disconnects" />

                        <TextBlock Text="{Binding BrowseStatusText, FallbackValue=''}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"
                                   automation:AutomationProperties.Name="Channel probe status"
                                   automation:AutomationProperties.LiveSetting="Polite" />

                        <ListBox ItemsSource="{Binding Channels}"
                                 SelectedItem="{Binding SelectedChannel, Mode=TwoWay}"
                                 DisplayMemberPath="DisplayText"
                                 MinHeight="130"
                                 automation:AutomationProperties.Name="Available channels"
                                 automation:AutomationProperties.HelpText="Pick a channel — its path is copied into the Channel path field above" />
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
