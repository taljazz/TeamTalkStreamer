<!--
  ExcludedProcessWindow.xaml
  ==========================
  Modal dialog for picking one process whose audio should be excluded
  from the loopback capture (primary use case: the user's screen reader).
  The picker only lists sessions that are actively producing sound —
  a Refresh button re-enumerates so the user can start their screen
  reader and then pick it without reopening the dialog.
-->
<Window x:Class="TeamTalkStreamer.App.Views.ExcludedProcessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        mc:Ignorable="d"
        Title="Excluded apps"
        Height="560" Width="500"
        MinHeight="400" MinWidth="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        automation:AutomationProperties.Name="Excluded apps picker dialog">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="90" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="12" LastChildFill="True">

        <!-- ==================== Footer (docked bottom) ==================== -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="Save"
                    IsDefault="True"
                    Command="{Binding SaveCommand}"
                    automation:AutomationProperties.Name="Save selection as excluded app"
                    automation:AutomationProperties.HelpText="Sets the highlighted session as the app whose audio is removed from the loopback capture" />
            <Button Content="Clear"
                    Command="{Binding ClearCommand}"
                    automation:AutomationProperties.Name="Clear exclusion"
                    automation:AutomationProperties.HelpText="Removes any saved exclusion — future streams include the full system audio mix" />
            <Button Content="Cancel"
                    IsCancel="True"
                    Command="{Binding CancelCommand}"
                    Margin="0"
                    automation:AutomationProperties.Name="Cancel — discard changes" />
        </StackPanel>

        <!-- ==================== Body ==================== -->
        <StackPanel>

            <!-- Currently-saved exclusion header. Updates if the user
                 saves or clears from this dialog. -->
            <TextBlock Text="{Binding CurrentExclusionLabel}"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="0,0,0,12"
                       automation:AutomationProperties.Name="Currently excluded app"
                       automation:AutomationProperties.LiveSetting="Polite" />

            <!-- Instructions for the user -->
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                Pick one currently-running app whose audio should be skipped
                during streaming. The list shows only apps that are making
                sound right now; if your screen reader isn't here yet, make
                it speak something and then press Refresh.
            </TextBlock>

            <Button Content="Refresh"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,8"
                    Command="{Binding RefreshCommand}"
                    automation:AutomationProperties.Name="Refresh active session list"
                    automation:AutomationProperties.HelpText="Re-enumerates audio sessions currently producing sound" />

            <TextBlock Text="{Binding StatusText}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"
                       automation:AutomationProperties.Name="Session refresh status"
                       automation:AutomationProperties.LiveSetting="Polite" />

            <TextBlock Text="Active audio sessions:" FontWeight="Bold" />
            <ListBox ItemsSource="{Binding Sessions}"
                     SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                     DisplayMemberPath="DisplayText"
                     MinHeight="200"
                     automation:AutomationProperties.Name="Active audio sessions"
                     automation:AutomationProperties.HelpText="Pick the app whose audio should be excluded from the loopback capture" />

        </StackPanel>

    </DockPanel>
</Window>
